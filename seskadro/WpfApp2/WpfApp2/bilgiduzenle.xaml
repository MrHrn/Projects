<Window x:Class="WpfApp2.bilgiduzenle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bilgi Düzenle" 
        Height="480" 
        Width="780"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResize"
        Background="White" 
        Loaded="Window_Loaded">

    <Grid Margin="24,24,24,9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık Alanı -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Profil Bilgilerini Düzenle" 
                       FontSize="22" 
                       FontWeight="SemiBold"/>
            <TextBlock Text="E-posta, ad, soyad ve sosyal medya bilgilerinizi buradan güncelleyebilirsiniz." 
                       Foreground="#6B7280" 
                       FontSize="13" 
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Ana İçerik -->
        <Grid Grid.Row="1" Margin="0,0,0,45" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <!-- Form Alanı -->
            <StackPanel Grid.Column="0" Margin="0,0,28,-14">
                <TextBlock Text="E-posta" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="txtEmail" Height="36" Padding="12,8"/>

                <TextBlock Text="Ad" FontWeight="SemiBold" Margin="0,16,0,6"/>
                <TextBox x:Name="txtAd" Height="36" Padding="12,8"/>

                <TextBlock Text="Soyad" FontWeight="SemiBold" Margin="0,16,0,6"/>
                <TextBox x:Name="txtSoyad" Height="36" Padding="12,8"/>

                <!-- Sosyal Medya -->
                <TextBlock Text="Sosyal Medya (Opsiyonel)" 
                           FontWeight="SemiBold" 
                           Margin="0,20,0,8"/>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Sosyal Medya" 
                               Width="110" 
                               VerticalAlignment="Center"
                               FontWeight="Medium"/>
                    <TextBox x:Name="sosyalmedya" Height="36" Padding="12,8"/>
                </DockPanel>

                <!-- İstersen buraya Instagram, LinkedIn vs. ekleyebilirsin -->
            </StackPanel>

            <!-- Bilgi Paneli -->
            <Border Grid.Column="1" 
                    Background="#F8FAFC" 
                    BorderBrush="#E5E7EB" 
                    BorderThickness="1" 
                    Padding="20" 
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Notlar" 
                               FontWeight="SemiBold" 
                               FontSize="15"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="• E-posta adresi giriş yaparken kullanılır." 
                               TextWrapping="Wrap" 
                               Foreground="#4B5563" 
                               Margin="0,0,0,10"/>

                    <TextBlock Text="• Sosyal medya alanlarına kullanıcı adınızı veya tam URL'yi yazabilirsiniz." 
                               TextWrapping="Wrap" 
                               Foreground="#4B5563"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alt Butonlar -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,24,0,0">

            <Button x:Name="btnKaydet" 
                    Content="KAYDET" 
                    Width="130" 
                    Height="40" 
                    Margin="12,0,0,0"
                    Background="#10B981" 
                    Foreground="White"
                    FontWeight="SemiBold" Click="btnKaydet_Click"/>
        </StackPanel>
    </Grid>
</Window>