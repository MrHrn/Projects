<Window x:Class="WpfApp2.sifreyenile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Şifre Yenile" Height="360" Width="460"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC" ResizeMode="NoResize">

    <Border Background="White" CornerRadius="10" Margin="12" BorderBrush="#D0D7E0" BorderThickness="1">
        <StackPanel Margin="24">
            <TextBlock Text="Şifre Yenileme" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12" HorizontalAlignment="Center"/>

            <TextBlock Text="E-posta" FontWeight="SemiBold" Foreground="Gray" Margin="0,6,0,2"/>
            <TextBox x:Name="txtEmail" Padding="8" FontSize="14"/>

            <TextBlock Text="Kullanıcı Türü" FontWeight="SemiBold" Foreground="Gray" Margin="0,12,0,2"/>
            <ComboBox x:Name="kullanicitip" Height="32" FontSize="14">
                <ComboBoxItem>Admin</ComboBoxItem>
                <ComboBoxItem>Seslendirme Sanatçısı</ComboBoxItem>
                <ComboBoxItem>Kullanıcı</ComboBoxItem>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,18,0,0">
                <Button x:Name="btnGonder" Content="GÖNDER" Width="120" Height="36" Background="#3B82F6" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Click="btnGonder_Click"/>
                <Button x:Name="btnAnasayfa" Content="ANASAYFA" Width="120" Height="36" Background="#E5E7EB" Click="btnAnasayfa_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
