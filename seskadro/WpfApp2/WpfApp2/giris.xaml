<Window x:Class="WpfApp2.giris"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seskadro - Giriş" Height="560" Width="500"
        WindowStartupLocation="CenterScreen" Background="#F0F4F8"
        ResizeMode="NoResize" Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>

        <!-- Link görünümlü buton stili -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="White" CornerRadius="12" BorderBrush="#D0D7E0" BorderThickness="1" Margin="20">
        <StackPanel Margin="40" VerticalAlignment="Center">
            <TextBlock Text="Seskadro" FontSize="36" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
            <TextBlock Text="Giriş Yap" FontSize="20" Margin="0,10,0,30" HorizontalAlignment="Center"/>

            <TextBlock Text="E-posta"/>
            <TextBox Margin="0,0,0,15" Padding="8" Name="eposta"/>

            <TextBlock Text="Parola"/>
            <PasswordBox Margin="0,0,0,8" Padding="8" Name="parola"/>

            <!-- Şifremi unuttum: artık link görünümlü buton -->
            <Button Style="{StaticResource LinkButton}" Click="SifremiUnuttum_Click">Şifremi unuttum?</Button>

            <TextBlock Text="Kullanıcı Türü"/>
            <ComboBox Margin="0,0,0,25" Name="turcombo">
                <ComboBoxItem>Admin</ComboBoxItem>
                <ComboBoxItem>Seslendirme Sanatçısı</ComboBoxItem>
                <ComboBoxItem>Kullanıcı</ComboBoxItem>
            </ComboBox>

            <Button Content="Giriş Yap" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Click="Button_Click"/>
        </StackPanel>
    </Border>
</Window>