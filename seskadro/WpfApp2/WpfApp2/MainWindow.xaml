<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.blend.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:av1="http://schemas.microsoft.com/expression/blend/2008" x:Class="WpfApp2.MainWindow" 
        x:Name="anasayfa" 
        mc:Ignorable="av av1" 
        Title="SesKadro - Ana Panel" 
        Height="620" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip" 
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="CompactCardButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,30"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="MinWidth" Value="280"/>
            <Setter Property="MinHeight" Value="140"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="315" ShadowDepth="2" BlurRadius="10" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AvatarStyle" TargetType="{x:Type Ellipse}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" Margin="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#6366F1" CornerRadius="10,10,0,0" Grid.ColumnSpan="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="adsoyad" Text="Kullanıcı adı " Foreground="White" FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <!-- Tıklanabilir avatar: görünüm aynı kalır, Click event ekli -->
                    <Button x:Name="btnAvatar" Background="Transparent" BorderThickness="0" Margin="0,0,12,0" Click="btnAvatar_Click">
                        <Ellipse Style="{StaticResource AvatarStyle}" Fill="#4F46E5"/>
                    </Button>

                    <Button Content="Çıkış" Margin="16,0,0,0" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="13" Click="Button_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="231*"/>
                    <ColumnDefinition Width="67*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="79*"/>
                    <RowDefinition Height="99*"/>
                </Grid.RowDefinitions>

                <UniformGrid x:Name="MenuGrid" Rows="2" Columns="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="143,103,0,0" Panel.ZIndex="1" Grid.RowSpan="2" Grid.ColumnSpan="2">
                    <Button x:Name="yapimekle" Style="{StaticResource CompactCardButton}" Background="#FFF59E0B" Click="yapimekle_Click">
                        <TextBlock Text="Yapım Ekle" TextWrapping="Wrap" TextAlignment="Center" FontSize="27"/>
                    </Button>
                    <Button x:Name="kadrolistele" Style="{StaticResource CompactCardButton}" Background="#10B981" Click="kadrolistele_Click">
                        <TextBlock Text="Mevcut Kadroları Gör" TextWrapping="Wrap" TextAlignment="Center" FontSize="27"/>
                    </Button>
                    <Button x:Name="karakterekleme" Style="{StaticResource CompactCardButton}" Background="#EF4444" Click="karakterekle_Click">
                        <TextBlock Text="Karakter Ekle" TextWrapping="Wrap" TextAlignment="Center" FontSize="27" />
                    </Button>
                    <Button x:Name="yapimtur" Style="{StaticResource CompactCardButton}" Background="#8B5CF6" Click="yapimtur_Click">
                        <TextBlock Text="Yapım Türü Ekle" TextWrapping="Wrap" TextAlignment="Center" FontSize="27"/>
                    </Button>
                </UniformGrid>

                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Visibility="Visible" Navigated="MainFrame_Navigated" Panel.ZIndex="2" Grid.RowSpan="2" Grid.ColumnSpan="2"/>

            </Grid>
        </Grid>
    </Border>
</Window>