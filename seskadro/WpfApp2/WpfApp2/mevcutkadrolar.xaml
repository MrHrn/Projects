<Page x:Class="WpfApp2.mevcutkadrolar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Mevcut Kadrolar" Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Hafif açılış animasyonu -->
        <Storyboard x:Key="PageEnter">
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.30" />
            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="12" To="0" Duration="0:0:0.30" />
        </Storyboard>

        <!-- Buton etkileşim stili -->
        <Style x:Key="InteractiveButton" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="0" Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.035" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.035" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="8" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.18" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="0" Duration="0:0:0.10"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0" Duration="0:0:0.10"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnter}"/>
        </EventTrigger>
    </Page.Triggers>

    <Grid x:Name="RootGrid" Margin="20" Opacity="0" Background="White">
        <Grid.RenderTransform>
            <TranslateTransform Y="0"/>
        </Grid.RenderTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <ComboBox x:Name="cmbYapimSec" Width="300" Height="40" VerticalContentAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
            <Button Content="ARA" Width="100" Height="40" Background="#6366F1" Foreground="White" Click="btnAra_Click" Style="{StaticResource InteractiveButton}"/>
        </StackPanel>

        <DataGrid x:Name="dgKadrolar" Grid.Row="1" AutoGenerateColumns="True" 
                  Background="WhiteSmoke" BorderBrush="#E5E7EB" BorderThickness="1" 
                  IsReadOnly="True" GridLinesVisibility="Horizontal"/>

        <Button Grid.Row="2" Content="GERİ DÖN" Width="120" Height="40" HorizontalAlignment="Left" Margin="0,20,0,0" Click="btnGeri_Click" Style="{StaticResource InteractiveButton}"/>
    </Grid>
</Page>