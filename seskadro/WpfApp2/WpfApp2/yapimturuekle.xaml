<Page x:Class="WpfApp2.yapimturuekle"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Yapım Türü Ekle" Background="White">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ANA SAYFA" FontWeight="Bold" FontSize="16" Foreground="Gray"/>
            <TextBlock Text="YAPIM TÜRÜ" FontWeight="Bold" FontSize="24" Margin="0,10,0,10"/>

            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtYapimTuru" Width="300" Height="40" FontSize="18" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button x:Name="btnEkle" Content="EKLE" Width="100" Height="40" Background="#10B981" Foreground="White" Click="btnEkle_Click"/>
                <Button x:Name="btnDuzenleTur" Content="DÜZENLE" Width="100" Height="40" Margin="8,0,0,0" Background="#F59E0B" Click="btnDuzenleTur_Click"/>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dgYapimTurleri" Grid.Row="1" Background="WhiteSmoke" 
                  AutoGenerateColumns="True" IsReadOnly="True" Margin="0,0,0,20" Height="280" SelectionMode="Single" SelectionChanged="dgYapimTurleri_SelectionChanged"/>

        <Button Grid.Row="2" Content="GERİ DÖN" Width="120" Height="40" HorizontalAlignment="Left" 
                Click="btnGeri_Click" Background="#E5E7EB"/>
    </Grid>
</Page>