<Page x:Class="WpfApp2.yapimekle"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Yapım Ekle" Background="White">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Yapım Ekle" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Yeni yapım bilgilerini girin" Foreground="Gray" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Top" Width="760">
            <StackPanel Width="520">
                <TextBlock Text="Yapım Adı" FontWeight="SemiBold" Margin="0,6,0,4"/>
                <TextBox x:Name="txtYapimAdi" Height="36" Padding="6"/>

                <TextBlock Text="Yapım Yılı" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBox x:Name="txtYapimYili" Height="36" Padding="6"/>

                <TextBlock Text="Yapım Türü" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <ComboBox x:Name="cmbYapimTuru" Height="36"/>
            </StackPanel>

            <TextBlock Text="Kayıtlı Yapımlar" Margin="0,18,0,6" FontWeight="SemiBold"/>
            <DataGrid x:Name="dgYapimlar" AutoGenerateColumns="True" Height="220" 
                      Background="WhiteSmoke" BorderBrush="#E5E7EB" BorderThickness="1" IsReadOnly="True"
                      SelectionMode="Single" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,18,0,0">
            <Button x:Name="btnKaydet" Content="KAYDET" Width="120" Height="36" Background="#10B981" Foreground="White" Click="btnKaydet_Click"/>
            <Button x:Name="btnGeri" Content="GERİ" Width="120" Height="36" Margin="12,0,0,0" Click="btnGeri_Click" Background="#E5E7EB"/>
        </StackPanel>
    </Grid>
</Page>
