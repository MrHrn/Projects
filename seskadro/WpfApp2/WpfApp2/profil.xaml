<Page x:Class="WpfApp2.profil"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Profil" Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sol: avatar -->
        <Border Grid.Column="0" Background="#F3F4F6" CornerRadius="8" Padding="12" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                <Ellipse Width="120" Height="120" Fill="#4F46E5" Stroke="White" StrokeThickness="3" />
                <Button Content="Fotoğraf Değiştir" Margin="0,12,0,0" Padding="6,4" Width="140" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Sağ: bilgiler -->
        <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="14" Margin="12,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0">
                    <TextBlock Text="İSİM :" FontWeight="Bold" Foreground="Gray" />
                    <TextBlock x:Name="txtIsim" Text="-" FontSize="16" Margin="0,4,0,8"/>

                    <TextBlock Text="SOY İSİM :" FontWeight="Bold" Foreground="Gray" />
                    <TextBlock x:Name="txtSoyIsim" Text="-" FontSize="16" Margin="0,4,0,8"/>

                    <TextBlock Text="MAİL :" FontWeight="Bold" Foreground="Gray" />
                    <TextBlock x:Name="txtMail" Text="-" FontSize="16" Margin="0,4,0,8"/>

                    <TextBlock x:Name="txtKatkiLabel" Text="KATKI PUANINIZ :" FontWeight="Bold" Foreground="Gray" />
                    <TextBlock x:Name="txtKatki" Text="-" FontSize="16" Margin="0,4,0,8"/>
                </StackPanel>

                <!-- Sağ üst: rütbe (label4 görünümü) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <TextBlock x:Name="rankHeader" Text="RÜTBE" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="label4" Text="-" FontSize="20" FontWeight="SemiBold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Alt aksiyon butonları: Şifre değiştir ve Ana sayfa -->
                <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,18,0,0" >
                    <Button Content="Bilgilerini Düzenle" Width="160" Height="36" Margin="0,0,10,0"/>
                    <Button x:Name="btnSifreDegistir" Content="ŞİFRE DEĞİŞTİR" Width="160" Height="36" Margin="0,0,10,0" Click="btnSifreDegistir_Click"/>
                    <Button x:Name="btnAnasayfa" Content="ANASAYFA" Width="140" Height="36" Margin="0,0,0,0" Click="btnAnasayfa_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
